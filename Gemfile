# Local development only. GitHub Pages builds the site with its own bundled Jekyll;
# this Gemfile just lets you preview locally with `bundle exec jekyll serve`.
# (Gemfile and Gemfile.lock are excluded from the build in _config.yml.)
source "https://rubygems.org"

# Use the same Jekyll + plugin versions GitHub Pages runs, so local == production.
gem "github-pages", group: :jekyll_plugins

# Required to run `jekyll serve` on Ruby 3.x (WEBrick is no longer bundled with Ruby).
gem "webrick"
